{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "7b1c334ead9242f38b296659b74a596f",
    "m_Title": "5. Height map -> Color",
    "m_Content": "We finally have a nice enough height map modeling our dunes. Let's add one last feature to model the grainy appearance of sand.\nCreate a Simple Noise node: this will generate uniform noise. Multiply it by a small constant (such as 0.2) and sum it to the output of PolygonGradient. Then, pass the result through a Saturate node to ensure its values lie in [0;1]. \nAs we did previously, create a Sample Gradient node and select two different shades of sand colors at t = 0 and t = 1. Feed the output of Saturate into the Time pin of Sample Gradient. That's it for our color: you may forward the output to the Base Color of the Fragment Shader.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": 1770.0,
        "y": -62.666664123535159,
        "width": 821.33349609375,
        "height": 109.99998474121094
    },
    "m_Group": {
        "m_Id": ""
    }
}

