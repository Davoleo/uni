LAB*/[Ll]ibrary/
LAB*/[Tt]emp/ 
LAB*/[Oo]bj/ 
LAB*/[Bb]uild/ 
LAB*/[Bb]uilds/ 
LAB*/[Ll]ogs/
LAB*/[Uu]ser[Ss]ettings/
LAB*/Assets/AssetStoreTools*

# log files
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
LAB*/[Mm]emoryCaptures/

# Recordings can get excessive in size
LAB*/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# LAB*/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
LAB*/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# Addressables default ignores, before user customizations
/ServerData
LAB*/[Aa]ssets/StreamingAssets/aa*
LAB*/[Aa]ssets/AddressableAssetsData/link.xml*
LAB*/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
LAB*/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
LAB*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
LAB*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
LAB*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
LAB*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
LAB*/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*