{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "061a8f8b18c948a986e2706a273f59a1",
    "m_Title": "1. Adding input nodes",
    "m_Content": "Input nodes are used to access properties of the scene during shading.\nFor example, we want to access the surface normal of the rendered object \nRight click > Create Node, then select the Input category. From here, select Geometry and then Normal Vector.\n",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -500.66668701171877,
        "y": -115.33332824707031,
        "width": 262.0,
        "height": 136.66665649414063
    },
    "m_Group": {
        "m_Id": ""
    }
}

{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "0a18440f015e41e28d4b3616d8f1b8e6",
    "m_Title": "3. Normal shading",
    "m_Content": "Plug the out pin of \"Normal Vector\" into Fragment > Base Color. Save the shader (CTRL + S) and Unity will compile it, effectively turning the ShaderGraph into code.\nReturn to \"Scene\".",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -215.33331298828126,
        "y": 216.6666717529297,
        "width": 224.6666717529297,
        "height": 124.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

