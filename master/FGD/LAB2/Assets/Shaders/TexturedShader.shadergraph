{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "65e62675a9b74fde92476e295a67374c",
    "m_Title": "1. Texture sampling",
    "m_Content": "Let's start by creating a \"Sample Texture 2D\" node right here.\nThis is a node which allows us to extract texture information and map it to the surface.\nYou will see that the preview is gray: we still need to plug in the surface coordinates and the actual texture.\n\nClick on the \"Texture\" pin to attach an asset to it. You should find the \"FlipbookTest\" texture. Select that.\nThe node preview will show the texture. Now, let's map it onto the surface.\n",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -994.6666259765625,
        "y": -132.6666717529297,
        "width": 339.2293701171875,
        "height": 180.3431396484375
    },
    "m_Group": {
        "m_Id": ""
    }
}

