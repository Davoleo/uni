{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "caecdf4efd6749598721ea80071eeced",
    "m_Title": "4. Glass color",
    "m_Content": "We're almost there: we just need to set the glass color in some nice-looking way.\n\nCreate a UV node and Split its coordinates. We will only use these to define the color transition. Now, create a Sample Gradient node and plug the first coordinate of the UVs into the Time pin. Open the Gradient parameter and manually define some color gradient you like.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -761.3333129882813,
        "y": -206.66665649414063,
        "width": 442.0,
        "height": 126.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

