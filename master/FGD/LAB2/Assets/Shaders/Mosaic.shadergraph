{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "c0b7294f92974f0f987d452f214cd4d2",
    "m_Title": "1. Hex Pattern",
    "m_Content": "Create a Hex Lattice node: this will instantiate the subgraph we just implemented. Set the input parameters to \nTiling: (10, 10)\nHex Scale: 1\nEdge Width: 0.2",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
