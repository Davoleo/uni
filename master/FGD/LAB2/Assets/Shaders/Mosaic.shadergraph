{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "47a965466f7e4298ba42a566fb1bb865",
    "m_Title": "2. Transparency",
    "m_Content": "We need to define which pieces are transparent (glass) and which are not (frame).\n\nLet's begin by inverting the output of the Hex Lattice (i.e., computing 1 - Out).\nThen, we will use a Branch node: these function just like If statements in programming.\nWe will set the True branch to 1.0 and the False branch to 0.8. Plug the output of the Branch node into the Alpha pin of the Fragment shader.\n\nLastly, we have to define the Predicate for branching: create a Comparison node. Plug (1 - Hex Lattice) into the A pin and set the B pin to 0.5. Set the Comparison mode to \"Greater or equal\", and forward the Output to the Predicate pin of the Branch we created.\n",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -72.66667175292969,
        "y": 848.6666870117188,
        "width": 500.66668701171877,
        "height": 192.6666259765625
    },
    "m_Group": {
        "m_Id": ""
    }
}

{
    "m_SGVersion": 2,
    "m_Type": "UnityEditor.Rendering.Universal.ShaderGraph.UniversalLitSubTarget",
    "m_ObjectId": "49aef360b0d74385b19866fe1d1517bd",
    "m_WorkflowMode": 1,
    "m_NormalDropOffSpace": 0,
    "m_ClearCoat": false,
    "m_BlendModePreserveSpecular": true
}

{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "5893b7218d6143969450ad8bcce808bf",
    "m_Title": "Mosaic Material",
    "m_Content": "We will define a simple Mosaic material. The goal is to get a regular collection of glass hexagons in multiple colors, connected by a metallic frame.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": 225.33334350585938,
        "y": -580.0,
        "width": 277.33331298828127,
        "height": 112.00003051757813
    },
    "m_Group": {
        "m_Id": ""
    }
}

