{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "c331f57d343d49c3ac38ac26a4b6d2e3",
    "m_Title": "5. Animation (2)",
    "m_Content": "Sum the outputs of the Multiply nodes with an Add node. Feed this sum to a Sine node: this allows for looping as time passes.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -692.0,
        "y": 224.6666717529297,
        "width": 200.00003051757813,
        "height": 100.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

