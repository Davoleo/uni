{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "99b9b9864f9f4edea68b92ba1d2e6aab",
    "m_Title": "11. Finishing touch (2)",
    "m_Content": "Now, note that if only the x component of the vertices changes, the same will hold for the normals. Create another Vector 3 and set it to (0, 0, 1). However, this time we will change the x component to -cos(t). \"t\" here is the value we feed to the Sine node in (5). Simply pass it through a Cosine and a Negate node.\n\nLastly, we will decide which normal to use via linear interpolation: create a Lerp node, feed the (0, 0, 1) normal to the A pin and the other one to the B pin. For the T pin, we will use the output of the Multiply node in (8), our wind scaling factor.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -383.4285583496094,
        "y": 631.4285278320313,
        "width": 343.6048889160156,
        "height": 209.08251953125
    },
    "m_Group": {
        "m_Id": ""
    }
}

