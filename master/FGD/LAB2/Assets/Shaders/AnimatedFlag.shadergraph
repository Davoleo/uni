{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "8cfc9f10f89c4bada4df517005e77653",
    "m_Title": "10. Finishing touch (1)",
    "m_Content": "Much better now! However, there's still something not quite right: if the vertices change, so will the surface normals, and we have to somehow inform the vertex shader about this. \n\nRecall: The flag doesn't move at the pole, while we have a scaled Sine animation on the other vertices. Thus, the normal at the pole will be (0, 0, 1), i.e., the original normal value. Let's start by creating a Vector 3 node and setting it to (0, 0, 1).",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -727.3333129882813,
        "y": 630.0,
        "width": 311.85784912109377,
        "height": 182.7509765625
    },
    "m_Group": {
        "m_Id": ""
    }
}

