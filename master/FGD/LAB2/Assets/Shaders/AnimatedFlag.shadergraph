{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "f19e5d563d274ad08cc9d5ec9b587e05",
    "m_Title": "7. Non-constant movement (1)",
    "m_Content": "Flags don't move identically over their entire surface. The portion closer to the pole will move less, while the end portion will move more. Let's model this: again, get the vertex positions (in Object space) and split them. The first component, again, will be our \"wind\" direction, and will also tell us how close we are to the pole!",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1584.666748046875,
        "y": 690.0,
        "width": 362.037109375,
        "height": 160.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

