{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "6ebf63afd4ce43daa393b531e085e4f6",
    "m_Title": "3. Flag behaviour",
    "m_Content": "Flags are, generally, planar square patches. In a very simplified model (with constant wind direction), we can say that the \"plane\" coordinates never change, and the animation happens only on the normal direction of the vertices.\nSo, let's split the Position coordinates with a Split node, and get the first component (which will be our \"wind\" direction). ",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1194.0,
        "y": -170.0,
        "width": 295.99993896484377,
        "height": 160.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.Vector1MaterialSlot",
    "m_ObjectId": "7230c4b7451149e7ac1fdb02e9f0f203",
