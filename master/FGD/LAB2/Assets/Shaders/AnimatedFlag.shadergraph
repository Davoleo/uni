{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "c7720c3f653344c5bdd0c0215388ddb8",
    "m_Title": "4. Animation (1)",
    "m_Content": "Create two Multiply nodes. In the first, plug the \"wind\" component of the vertices and the Wave Length parameter. In the other, plug the Wind Speed parameter and feed the output of a Time node. This allows us to define time-varying behaviour.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1327.3333740234375,
        "y": 178.6666717529297,
        "width": 258.666748046875,
        "height": 122.1568603515625
    },
    "m_Group": {
        "m_Id": ""
    }
}

