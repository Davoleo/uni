{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "ccdada89857745a58d94a06a6aec8921",
    "m_Title": "6. Combining",
    "m_Content": "Create a Combine node. Forward the first two components from the Split node we created in 3 to the first two components. Set the third component to the output of the Sine node.\n\nFinally, forward the output of the Combine to Vertex > Position. Return to Scene mode and see what happens (we're not done yet! Come back after looking).\n\nIf everything worked as intended, you should see the normal component of the flag surface moving with a sine wave, which is exactly what we implemented (not quite a flag yet).",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -300.66668701171877,
        "y": -208.0,
        "width": 367.102294921875,
        "height": 200.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

