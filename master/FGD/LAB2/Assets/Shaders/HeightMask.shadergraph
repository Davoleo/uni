{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "bff098b9a67e4f99b4cb5fe7edaf1850",
    "m_Title": "5. MOS masking",
    "m_Content": "We will finally interpolate the Metallic, Occlusion and Smoothness properties of the two materials.\n\nCreate a Vector 4 = (1, 1, 0.5, 1). These are the MOHS properties of the gold material. Now, Lerp the RGBA output of the MOHS texture (which we loaded in Step 1) with this vector. Split the output, and feed:\nR to Fragment > Metallic\nG to Fragment > Ambient Occlusion\nA to Fragment > Smoothness\n\nAnd with that, our masked shader is complete! Go back to scene mode.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": 1516.0,
        "y": 616.0,
        "width": 390.5921630859375,
        "height": 204.07366943359376
    },
    "m_Group": {
        "m_Id": ""
    }
}

