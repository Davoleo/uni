{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "f105fa59b220444e8a0f98d21480e8e1",
    "m_Title": "Height masking",
    "m_Content": "As our last step-by-step shader, we will see how to do material masking in a \"real\" setting, i.e., using albedo, normal and MOHS maps, as it's commonly done in game development.\n\nWe will apply a gold material is applied in the lower areas of the cobblestones first and then gradually rises until just the tops of the cobblestones show before being replaced completely by a stone material. In order for this effect to work correctly, one or both of the materials need good height data. This type of a transition works best on materials with varying heights - like the cobblestones.  Materials that are mostly flat won’t generate interesting effects with this technique\n",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -880.6666259765625,
        "y": -861.3333129882813,
        "width": 556.6666259765625,
        "height": 164.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

