{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "93331e9b43d642489dad4aa76d4b3e79",
    "m_Title": "3. Albedo masking",
    "m_Content": "The albedo map contains the color of the surface. We will use our mask to alternate between the stone albedo and the gold color.\n\nFirst, create a Sample Texture 2D node, which you will use to load the cobblestone_d.png texture (ensure Type = Default and Space = Tangent), and a Color node, which you will set to some gold-looking color.\n\nFinally, create a Lerp node, which you will feed with the albedo texture (in the A pin), the gold color (in the B pin) and the output of Step 2 (in the T pin). Feed the output of Lerp into Fragment > Base Color.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": 1022.0,
        "y": -908.0,
        "width": 563.0,
        "height": 160.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

