    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "d3572ee963df4eaf823077f9743c94ca",
    "m_Title": "1. MOHS",
    "m_Content": "MOHS textures contain Metalic, Occlusion, Height, and Smoothness information in their channels. We will now use this texture's Height information to perform height masking.\nFirst, create a SampleTexture2D node: for its texture asset, select cobblestone_mohs.png, and ensure Type is Default and Space is Tangent.\n",
    "m_TextSize": 0,
    "m_Theme": 0,
