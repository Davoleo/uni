{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "6becd21ab44849d5b839df435d5287b7",
    "m_Title": "4. Normal masking",
    "m_Content": "Very similarly, for the normal information we will load the cobblestones_n.png texture in a Sample Texture 2D node, and we will Lerp its RGBA output with a Vector3 = (0, 0, 1). As before, use the output of Step 2 as the interpolant.\n\nFeed the output of Lerp into Fragment > Normal.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -156.0,
        "y": 665.0,
        "width": 358.0,
        "height": 155.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

