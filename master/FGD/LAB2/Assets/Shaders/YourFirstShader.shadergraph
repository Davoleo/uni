{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "4810f212ad7a463ca3777d11cc9a04e2",
    "m_Title": "1. Configuration",
    "m_Content": "Here you can define variables that can be modified for instances of materials compiled from this shader!\nAdd a Color input and name it \"Color\".\n",
    "m_TextSize": 0,
    "m_Theme": 0,
