    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "76e846fbba2f42e4bbe5ca2535240cd5",
    "m_Title": "2. Base color",
    "m_Content": "Let's keep it simple in this example: just use your \"Color\" input and connect it to the Base Color pin of the shader. To do this, just drag it from the parameter list to here, and connect the pins.\nWhen you're done, return to Scene mode.",
