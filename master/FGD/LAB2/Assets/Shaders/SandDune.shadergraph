{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "252e69ac4f0943b7a30cc5bd36ed5f53",
    "m_Title": "2. Perlin noise",
    "m_Content": "In Unity's ShaderGraph, Perlin noise is generated via a Gradient Noise node. Create that and another float parameter Perlin Scale, which we will feed into the Scale pin of the Gradient noise node. Then, use a Remap node to modify the output distribution of Perlin to (-1, 1). Do this by setting the input bounds to (0, 1) and the output bounds to (-1, 1). Multiply the output by another new float parameter Distort Amplitude.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1114.666748046875,
        "y": -407.3333435058594,
        "width": 854.0,
        "height": 100.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

