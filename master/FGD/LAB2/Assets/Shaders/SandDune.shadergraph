{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "b914c18f3f4544a2ac53487288bf190a",
    "m_Title": "3. UV editing",
    "m_Content": "In order to make our material more customizable, we will allow for a) rotating the UV domain and b) smoothly repeating the UV map along the vertical axis.\nFirst, create a Rotate node and feed the output of step 1 into its UV pin. Create a new float parameter Rotation and feed it into the Rotation pin. Split the output vector. Now, we will multiply its second component by 2 * PI * Sine Frequency, another float parameter that we will now add. To obtain 2 * PI, use a Constant node and select TAU. \nFinally, feed the output of the multiplication into a Sine node.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1361.0,
        "y": 758.0,
        "width": 529.0,
        "height": 156.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

