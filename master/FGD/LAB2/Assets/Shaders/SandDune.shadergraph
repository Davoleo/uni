{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "643bf576d1c246c2b5c6cc7527aa838d",
    "m_Title": "6. Forgetting anything?",
    "m_Content": "Our normals are still flat! Fortunately, we can solve this problem in 1 step: create a Normal From Height node, and feed it the output of PolygonGradient (our height map). Go ahead and forward the output to the Normal output of the Fragment shader: our sand material is done!",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": 2151.33349609375,
        "y": 748.0,
        "width": 460.66650390625,
        "height": 110.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

