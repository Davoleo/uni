    \"m_Type\": \"UnityEditor.ShaderGraph.StickyNoteData\",\n    \"m_ObjectId\":
    \"5aa59f9ae8b649c4a33c63785660d8c6\",\n    \"m_Title\": \"Hex Lattice Pattern\",\n   
    \"m_Content\": \"We will implement a pattern of regular hexagons on a flat domain,
    and use it to define a mosaic-like material.\",\n    \"m_TextSize\": 0,\n   
    \"m_Theme\": 0,\n    \"m_Position\": {\n        \"serializedVersion\": \"2\",\n       
