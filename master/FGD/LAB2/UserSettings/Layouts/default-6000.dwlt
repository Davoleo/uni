    \"m_Id\": \"\"\n    }\n}\n\n{\n    \"m_SGVersion\": 0,\n    \"m_Type\": \"UnityEditor.ShaderGraph.StickyNoteData\",\n   
    \"m_ObjectId\": \"caecdf4efd6749598721ea80071eeced\",\n    \"m_Title\": \"4.
    Glass color\",\n    \"m_Content\": \"We're almost there: we just need to set
    the glass color in some nice-looking way.\\n\\nCreate a UV node and Split its
    coordinates. We will only use these to define the color transition. Now, create
    a Sample Gradient node and plug the first coordinate of the UVs into the Time
    pin. Open the Gradient parameter and manually define some color gradient you
    like.\",\n    \"m_TextSize\": 0,\n    \"m_Theme\": 0,\n    \"m_Position\": {\n       
    \"serializedVersion\": \"2\",\n        \"x\": -761.3333129882813,\n        \"y\":
