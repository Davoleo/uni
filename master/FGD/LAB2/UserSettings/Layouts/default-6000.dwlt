    \"z\": 0.0,\n        \"w\": 0.0\n    }\n}\n\n{\n    \"m_SGVersion\": 0,\n   
    \"m_Type\": \"UnityEditor.ShaderGraph.BlockNode\",\n    \"m_ObjectId\": \"460572137f0c41cdb4d5a90c3cd32e11\",\n   
    \"m_Group\": {\n        \"m_Id\": \"\"\n    },\n    \"m_Name\": \"SurfaceDescription.Occlusion\",\n   
    \"m_DrawState\": {\n        \"m_Expanded\": true,\n        \"m_Position\": {\n           
    \"serializedVersion\": \"2\",\n            \"x\": 0.0,\n            \"y\": 0.0,\n           
    \"width\": 0.0,\n            \"height\": 0.0\n        }\n    },\n    \"m_Slots\":
    [\n        {\n            \"m_Id\": \"8482c22a3b42403fad737bba77b3a3f9\"\n       
    }\n    ],\n    \"synonyms\": [],\n    \"m_Precision\": 0,\n    \"m_PreviewExpanded\":
    true,\n    \"m_DismissedVersion\": 0,\n    \"m_PreviewMode\": 0,\n    \"m_CustomColors\":
    {\n        \"m_SerializableColors\": []\n    },\n    \"m_SerializedDescriptor\":
    \"SurfaceDescription.Occlusion\"\n}\n\n{\n    \"m_SGVersion\": 0,\n    \"m_Type\":
    \"UnityEditor.ShaderGraph.StickyNoteData\",\n    \"m_ObjectId\": \"47a965466f7e4298ba42a566fb1bb865\",\n   
    \"m_Title\": \"2. Transparency\",\n    \"m_Content\": \"We need to define which
    pieces are transparent (glass) and which are not (frame).\\n\\nLet's begin by
    inverting the output of the Hex Lattice (i.e., computing 1 - Out).\\nThen, we
    will use a Branch node: these function just like If statements in programming.\\nWe
    will set the True branch to 1.0 and the False branch to 0.8. Plug the output
    of the Branch node into the Alpha pin of the Fragment shader.\\n\\nLastly, we
    have to define the Predicate for branching: create a Comparison node. Plug (1
    - Hex Lattice) into the A pin and set the B pin to 0.5. Set the Comparison mode
    to \\\"Greater or equal\\\", and forward the Output to the Predicate pin of the
    Branch we created.\\n\",\n    \"m_TextSize\": 0,\n    \"m_Theme\": 0,\n    \"m_Position\":
