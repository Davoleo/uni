    1.0\n    }\n}\n\n{\n    \"m_SGVersion\": 0,\n    \"m_Type\": \"UnityEditor.ShaderGraph.CategoryData\",\n   
    \"m_ObjectId\": \"1eb614db69c946d28d4e86477346e220\",\n    \"m_Name\": \"\",\n   
    \"m_ChildObjectList\": []\n}\n\n{\n    \"m_SGVersion\": 0,\n    \"m_Type\": \"UnityEditor.ShaderGraph.BlockNode\",\n   
    \"m_ObjectId\": \"3802e9c25b7f4de7953010675282cb0c\",\n    \"m_Group\": {\n       
    \"m_Id\": \"\"\n    },\n    \"m_Name\": \"SurfaceDescription.Emission\",\n   
    \"m_DrawState\": {\n        \"m_Expanded\": true,\n        \"m_Position\": {\n           
    \"serializedVersion\": \"2\",\n            \"x\": 0.0,\n            \"y\": 0.0,\n           
    \"width\": 0.0,\n            \"height\": 0.0\n        }\n    },\n    \"m_Slots\":
    [\n        {\n            \"m_Id\": \"1d4bbafe74df4b7f8affb3e59eaec0fc\"\n       
    }\n    ],\n    \"synonyms\": [],\n    \"m_Precision\": 0,\n    \"m_PreviewExpanded\":
    true,\n    \"m_DismissedVersion\": 0,\n    \"m_PreviewMode\": 0,\n    \"m_CustomColors\":
    {\n        \"m_SerializableColors\": []\n    },\n    \"m_SerializedDescriptor\":
    \"SurfaceDescription.Emission\"\n}\n\n{\n    \"m_SGVersion\": 0,\n    \"m_Type\":
    \"UnityEditor.ShaderGraph.StickyNoteData\",\n    \"m_ObjectId\": \"3ca6db52fcd24d64950054735bedd480\",\n   
    \"m_Title\": \"5. Mixing\",\n    \"m_Content\": \"If we were to feed our color
    gradient straight into the Fragment base color, the metal frame would also get
    the same coloring. So, let's mix the two color maps: first, create a Color node
    and decide some metallic-looking color for the frame (gold, steel, bronze, ...).
    Now, we will create a Lerp node, and we will feed the new Color into the A pin,
    and the Sample Gradient output into the B pin. As for the interpolant, we will
    use the output of the Hex Lattice: this is 0 on the edge and 1 inside the hexes,
    so we will get B (glass color) on the hexes and A (metal color) on the edges
    (the frame). Plug the Lerp output into the Base Color of the Fragment shader:
    we're done!\",\n    \"m_TextSize\": 0,\n    \"m_Theme\": 0,\n    \"m_Position\":
    {\n        \"serializedVersion\": \"2\",\n        \"x\": 57.333335876464847,\n       
    \"y\": -300.6666564941406,\n        \"width\": 670.6666259765625,\n        \"height\":
    128.66665649414063\n    },\n    \"m_Group\": {\n        \"m_Id\": \"\"\n    }\n}\n\n{\n   
    \"m_SGVersion\": 0,\n    \"m_Type\": \"UnityEditor.ShaderGraph.ColorRGBMaterialSlot\",\n   
    \"m_ObjectId\": \"431c755b94534aa99d1dfe9903281528\",\n    \"m_Id\": 0,\n   
    \"m_DisplayName\": \"Base Color\",\n    \"m_SlotType\": 0,\n    \"m_Hidden\":
    false,\n    \"m_ShaderOutputName\": \"BaseColor\",\n    \"m_StageCapability\":
    2,\n    \"m_Value\": {\n        \"x\": 0.5,\n        \"y\": 0.5,\n        \"z\":
    0.5\n    },\n    \"m_DefaultValue\": {\n        \"x\": 0.5,\n        \"y\": 0.5,\n       
    \"z\": 0.5\n    },\n    \"m_Labels\": [],\n    \"m_ColorMode\": 0,\n    \"m_DefaultColor\":
    {\n        \"r\": 0.5,\n        \"g\": 0.5,\n        \"b\": 0.5,\n        \"a\":
    1.0\n    }\n}\n\n{\n    \"m_SGVersion\": 0,\n    \"m_Type\": \"UnityEditor.ShaderGraph.BlockNode\",\n   
    \"m_ObjectId\": \"460572137f0c41cdb4d5a90c3cd32e11\",\n    \"m_Group\": {\n       
    \"m_Id\": \"\"\n    },\n    \"m_Name\": \"SurfaceDescription.Occlusion\",\n   
    \"m_DrawState\": {\n        \"m_Expanded\": true,\n        \"m_Position\": {\n           
    \"serializedVersion\": \"2\",\n            \"x\": 0.0,\n            \"y\": 0.0,\n           
    \"width\": 0.0,\n            \"height\": 0.0\n        }\n    },\n    \"m_Slots\":
    [\n        {\n            \"m_Id\": \"8482c22a3b42403fad737bba77b3a3f9\"\n       
    }\n    ],\n    \"synonyms\": [],\n    \"m_Precision\": 0,\n    \"m_PreviewExpanded\":
    true,\n    \"m_DismissedVersion\": 0,\n    \"m_PreviewMode\": 0,\n    \"m_CustomColors\":
    {\n        \"m_SerializableColors\": []\n    },\n    \"m_SerializedDescriptor\":
    \"SurfaceDescription.Occlusion\"\n}\n\n{\n    \"m_SGVersion\": 0,\n    \"m_Type\":
    \"UnityEditor.ShaderGraph.StickyNoteData\",\n    \"m_ObjectId\": \"47a965466f7e4298ba42a566fb1bb865\",\n   
    \"m_Title\": \"2. Transparency\",\n    \"m_Content\": \"We need to define which
    pieces are transparent (glass) and which are not (frame).\\n\\nLet's begin by
    inverting the output of the Hex Lattice (i.e., computing 1 - Out).\\nThen, we
    will use a Branch node: these function just like If statements in programming.\\nWe
    will set the True branch to 1.0 and the False branch to 0.8. Plug the output
    of the Branch node into the Alpha pin of the Fragment shader.\\n\\nLastly, we
    have to define the Predicate for branching: create a Comparison node. Plug (1
    - Hex Lattice) into the A pin and set the B pin to 0.5. Set the Comparison mode
    to \\\"Greater or equal\\\", and forward the Output to the Predicate pin of the
    Branch we created.\\n\",\n    \"m_TextSize\": 0,\n    \"m_Theme\": 0,\n    \"m_Position\":
    {\n        \"serializedVersion\": \"2\",\n        \"x\": -72.66667175292969,\n       
    \"y\": 848.6666870117188,\n        \"width\": 500.66668701171877,\n        \"height\":
    192.6666259765625\n    },\n    \"m_Group\": {\n        \"m_Id\": \"\"\n    }\n}\n\n{\n   
    \"m_SGVersion\": 2,\n    \"m_Type\": \"UnityEditor.Rendering.Universal.ShaderGraph.UniversalLitSubTarget\",\n   
    \"m_ObjectId\": \"49aef360b0d74385b19866fe1d1517bd\",\n    \"m_WorkflowMode\":
    1,\n    \"m_NormalDropOffSpace\": 0,\n    \"m_ClearCoat\": false,\n    \"m_BlendModePreserveSpecular\":
    true\n}\n\n{\n    \"m_SGVersion\": 0,\n    \"m_Type\": \"UnityEditor.ShaderGraph.StickyNoteData\",\n   
    \"m_ObjectId\": \"5893b7218d6143969450ad8bcce808bf\",\n    \"m_Title\": \"Mosaic
    Material\",\n    \"m_Content\": \"We will define a simple Mosaic material. The
    goal is to get a regular collection of glass hexagons in multiple colors, connected
    by a metallic frame.\",\n    \"m_TextSize\": 0,\n    \"m_Theme\": 0,\n    \"m_Position\":
    {\n        \"serializedVersion\": \"2\",\n        \"x\": 225.33334350585938,\n       
    \"y\": -580.0,\n        \"width\": 277.33331298828127,\n        \"height\": 112.00003051757813\n   
    },\n    \"m_Group\": {\n        \"m_Id\": \"\"\n    }\n}\n\n{\n    \"m_SGVersion\":
    0,\n    \"m_Type\": \"UnityEditor.ShaderGraph.TangentMaterialSlot\",\n    \"m_ObjectId\":
    \"5e0082f3b7fa4eb3b1c9399363a7bbd7\",\n    \"m_Id\": 0,\n    \"m_DisplayName\":
    \"Tangent\",\n    \"m_SlotType\": 0,\n    \"m_Hidden\": false,\n    \"m_ShaderOutputName\":
    \"Tangent\",\n    \"m_StageCapability\": 1,\n    \"m_Value\": {\n        \"x\":
    0.0,\n        \"y\": 0.0,\n        \"z\": 0.0\n    },\n    \"m_DefaultValue\":
    {\n        \"x\": 0.0,\n        \"y\": 0.0,\n        \"z\": 0.0\n    },\n   
