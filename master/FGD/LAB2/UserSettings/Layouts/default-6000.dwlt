    \"m_Id\": \"\"\n    },\n    \"m_Name\": \"Tiling And Offset\",\n    \"m_DrawState\":
    {\n        \"m_Expanded\": true,\n        \"m_Position\": {\n            \"serializedVersion\":
    \"2\",\n            \"x\": -1479.0,\n            \"y\": 1040.0,\n           
    \"width\": 207.9998779296875,\n            \"height\": 325.9998779296875\n       
    }\n    },\n    \"m_Slots\": [\n        {\n            \"m_Id\": \"3516d995f98c42c393df7ff3f9beee18\"\n       
