    \"SurfaceDescription.Emission\"\n}\n\n{\n    \"m_SGVersion\": 0,\n    \"m_Type\":
    \"UnityEditor.ShaderGraph.StickyNoteData\",\n    \"m_ObjectId\": \"3ca6db52fcd24d64950054735bedd480\",\n   
    \"m_Title\": \"5. Mixing\",\n    \"m_Content\": \"If we were to feed our color
    gradient straight into the Fragment base color, the metal frame would also get
    the same coloring. So, let's mix the two color maps: first, create a Color node
    and decide some metallic-looking color for the frame (gold, steel, bronze, ...).
    Now, we will create a Lerp node, and we will feed the new Color into the A pin,
    and the Sample Gradient output into the B pin. As for the interpolant, we will
    use the output of the Hex Lattice: this is 0 on the edge and 1 inside the hexes,
    so we will get B (glass color) on the hexes and A (metal color) on the edges
    (the frame). Plug the Lerp output into the Base Color of the Fragment shader:
    we're done!\",\n    \"m_TextSize\": 0,\n    \"m_Theme\": 0,\n    \"m_Position\":
    {\n        \"serializedVersion\": \"2\",\n        \"x\": 1.0,\n        \"y\":
    -421.0,\n        \"width\": 671.0,\n        \"height\": 129.0\n    },\n    \"m_Group\":
    {\n        \"m_Id\": \"\"\n    }\n}\n\n{\n    \"m_SGVersion\": 0,\n    \"m_Type\":
    \"UnityEditor.ShaderGraph.UVNode\",\n    \"m_ObjectId\": \"3ceee919247641548cf794f7d33bfa5d\",\n   
    \"m_Group\": {\n        \"m_Id\": \"\"\n    },\n    \"m_Name\": \"UV\",\n   
    \"m_DrawState\": {\n        \"m_Expanded\": true,\n        \"m_Position\": {\n           
    \"serializedVersion\": \"2\",\n            \"x\": -777.0,\n            \"y\":
    -57.0,\n            \"width\": 208.0,\n            \"height\": 312.0\n       
    }\n    },\n    \"m_Slots\": [\n        {\n            \"m_Id\": \"887ee264b9084d218174464d741744f2\"\n       
    }\n    ],\n    \"synonyms\": [\n        \"texcoords\",\n        \"coords\",\n       
    \"coordinates\"\n    ],\n    \"m_Precision\": 0,\n    \"m_PreviewExpanded\":
    true,\n    \"m_DismissedVersion\": 0,\n    \"m_PreviewMode\": 0,\n    \"m_CustomColors\":
    {\n        \"m_SerializableColors\": []\n    },\n    \"m_OutputChannel\": 0\n}\n\n{\n   
    \"m_SGVersion\": 0,\n    \"m_Type\": \"UnityEditor.ShaderGraph.DynamicVectorMaterialSlot\",\n   
